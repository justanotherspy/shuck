{{template "header"}}
<p>Signed in as <code>{{.Login}}</code>.</p>
{{if .HasToken}}
<p>You have an active token.</p>
<ul>
  <li>Created: <code>{{.Created}}</code></li>
  <li>Last used: {{if .LastUsed}}<code>{{.LastUsed}}</code>{{else}}<span class="muted">never</span>{{end}}</li>
</ul>
<p class="warn">Regenerating immediately revokes the current token. Running
sessions using it will stop at their next reconnect and need the new token.</p>
<form method="post" action="/token">
  <input type="hidden" name="csrf" value="{{.CSRF}}">
  <button type="submit">Regenerate token</button>
</form>
{{else}}
<p>You have no token yet.</p>
<form method="post" action="/token">
  <input type="hidden" name="csrf" value="{{.CSRF}}">
  <button type="submit">Mint token</button>
</form>
{{end}}
{{template "footer"}}
